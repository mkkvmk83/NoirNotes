<UserControl x:Class="NoirNotes.Controls.FloatingToolPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="560" d:DesignWidth="64"
             Width="64">

    <UserControl.Resources>
        <!-- Colour swatch button style -->
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width"           Value="28" />
            <Setter Property="Height"          Value="28" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Width="28" Height="28">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                                  Color="Black" Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Width"  Value="32" />
                                <Setter TargetName="Bd" Property="Height" Value="32" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator line style -->
        <Style x:Key="Sep" TargetType="Rectangle">
            <Setter Property="Height"           Value="1" />
            <Setter Property="Fill"             Value="{StaticResource IronBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin"           Value="10,6" />
        </Style>
    </UserControl.Resources>

    <!-- The panel itself: a frosted charcoal pill -->
    <Border x:Name="PanelRoot"
            Background="#F01E1E1E"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#FF2A2A2A"
            MouseLeftButtonDown="OnPanelDragStart">

        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="32"
                              Color="#00000" Opacity="0.7" />
        </Border.Effect>

        <StackPanel Orientation="Vertical" Margin="8,12">

            <!-- ── Drag handle ──────────────────────────────────────────── -->
            <TextBlock Text="⠿"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Foreground="{StaticResource AshBrush}"
                       Margin="0,0,0,8"
                       Cursor="SizeAll"
                       ToolTip="Drag to move" />

            <!-- ── Tool buttons ────────────────────────────────────────── -->
            <ToggleButton x:Name="BtnFountainPen"
                          Style="{StaticResource ToolToggleButton}"
                          Click="OnToolSelected"
                          Tag="FountainPen"
                          IsChecked="True"
                          ToolTip="Fountain Pen  (pressure-sensitive)">
                <!-- SVG-path nib icon drawn inline -->
                <Viewbox Width="22" Height="22">
                    <Canvas Width="24" Height="24">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Data="M 12,2 L 20,12 L 12,22 L 4,12 Z M 12,2 L 12,22" />
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.5"
                              Data="M 12,15 L 12,24" />
                    </Canvas>
                </Viewbox>
            </ToggleButton>

            <ToggleButton x:Name="BtnChiselPen"
                          Style="{StaticResource ToolToggleButton}"
                          Click="OnToolSelected"
                          Tag="ChiselPen"
                          Margin="0,4,0,0"
                          ToolTip="Chisel Pen  (calligraphic nib)">
                <Viewbox Width="22" Height="22">
                    <Canvas Width="24" Height="24">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Data="M 4,4 L 20,20 M 4,4 L 4,12 M 4,4 L 12,4" />
                        <Rectangle Canvas.Left="10" Canvas.Top="10"
                                   Width="10" Height="5"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                   RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Canvas>
                </Viewbox>
            </ToggleButton>

            <ToggleButton x:Name="BtnHighlighter"
                          Style="{StaticResource ToolToggleButton}"
                          Click="OnToolSelected"
                          Tag="Highlighter"
                          Margin="0,4,0,0"
                          ToolTip="Highlighter  (editorial overlay)">
                <Viewbox Width="22" Height="22">
                    <Canvas Width="24" Height="24">
                        <Rectangle Canvas.Left="3" Canvas.Top="8"
                                   Width="18" Height="8"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                   Opacity="0.5" />
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.5"
                              Data="M 3,8 L 21,8 M 3,16 L 21,16" />
                    </Canvas>
                </Viewbox>
            </ToggleButton>

            <ToggleButton x:Name="BtnEraser"
                          Style="{StaticResource ToolToggleButton}"
                          Click="OnToolSelected"
                          Tag="Eraser"
                          Margin="0,4,0,0"
                          ToolTip="Eraser  (removes whole strokes)">
                <Viewbox Width="22" Height="22">
                    <Canvas Width="24" Height="24">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Data="M 4,18 L 10,6 L 20,6 L 20,18 Z" />
                        <Line X1="4" Y1="18" X2="20" Y2="18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="2" />
                    </Canvas>
                </Viewbox>
            </ToggleButton>

            <!-- ── Separator ───────────────────────────────────────────── -->
            <Rectangle Style="{StaticResource Sep}" Margin="8,10" />

            <!-- ── Brush width slider ──────────────────────────────────── -->
            <TextBlock Text="W" HorizontalAlignment="Center"
                       FontSize="10" Foreground="{StaticResource AshBrush}"
                       Margin="0,0,0,4" />
            <Slider x:Name="WidthSlider"
                    Orientation="Vertical" Height="60"
                    HorizontalAlignment="Center"
                    Minimum="1" Maximum="40" Value="5"
                    ValueChanged="OnWidthChanged"
                    Style="{StaticResource EditorialSlider}"
                    ToolTip="Brush width" />

            <Rectangle Style="{StaticResource Sep}" Margin="8,10" />

            <!-- ── Colour palette ──────────────────────────────────────── -->
            <!-- Row 1: Ink tones -->
            <UniformGrid Columns="2" Margin="0,0,0,6">
                <!-- Paper white -->
                <Button Style="{StaticResource SwatchButton}"
                        Background="#FFF4F0E8"
                        Click="OnColorSelected" Tag="#FFF4F0E8"
                        ToolTip="Paper" Margin="2" />
                <!-- Irvin Red -->
                <Button Style="{StaticResource SwatchButton}"
                        Background="#FFE34234"
                        Click="OnColorSelected" Tag="#FFE34234"
                        ToolTip="Irvin Red" Margin="2" />
                <!-- Warm Gold -->
                <Button Style="{StaticResource SwatchButton}"
                        Background="#FFC9A84C"
                        Click="OnColorSelected" Tag="#FFC9A84C"
                        ToolTip="Editorial Gold" Margin="2" />
                <!-- Midnight Blue -->
                <Button Style="{StaticResource SwatchButton}"
                        Background="#FF2A3F5F"
                        Click="OnColorSelected" Tag="#FF2A3F5F"
                        ToolTip="Ink Blue" Margin="2" />
                <!-- Graphite -->
                <Button Style="{StaticResource SwatchButton}"
                        Background="#FF8A8A8A"
                        Click="OnColorSelected" Tag="#FF8A8A8A"
                        ToolTip="Graphite" Margin="2" />
                <!-- Forest Green (corrections) -->
                <Button Style="{StaticResource SwatchButton}"
                        Background="#FF4A7C59"
                        Click="OnColorSelected" Tag="#FF4A7C59"
                        ToolTip="Proof Green" Margin="2" />
            </UniformGrid>

            <!-- Current colour indicator -->
            <Border x:Name="CurrentColorIndicator"
                    Width="28" Height="28"
                    CornerRadius="14"
                    Background="#FFF4F0E8"
                    HorizontalAlignment="Center"
                    BorderThickness="2"
                    BorderBrush="{StaticResource IronBrush}"
                    Margin="0,4,0,0"
                    ToolTip="Current colour" />

            <Rectangle Style="{StaticResource Sep}" Margin="8,10" />

            <!-- ── Opacity slider ──────────────────────────────────────── -->
            <TextBlock Text="α" HorizontalAlignment="Center"
                       FontSize="10" Foreground="{StaticResource AshBrush}"
                       Margin="0,0,0,4" />
            <Slider x:Name="OpacitySlider"
                    Orientation="Vertical" Height="50"
                    HorizontalAlignment="Center"
                    Minimum="0.05" Maximum="1.0" Value="1.0"
                    ValueChanged="OnOpacityChanged"
                    Style="{StaticResource EditorialSlider}"
                    ToolTip="Opacity" />

        </StackPanel>
    </Border>
</UserControl>
