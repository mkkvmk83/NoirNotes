<Application x:Class="NoirNotes.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!--═══════════════════════════════════════════════════════
                TYPOGRAPHY
                Primary: Cormorant Garamond (embedded in Resources/)
                Fallback: Georgia (shipped with Windows)
            ═══════════════════════════════════════════════════════-->
            <FontFamily x:Key="SerifDisplay">
                pack://application:,,,/Resources/#Cormorant Garamond, Georgia, serif
            </FontFamily>
            <FontFamily x:Key="SerifBody">
                pack://application:,,,/Resources/#Cormorant Garamond, Georgia, serif
            </FontFamily>

            <!--═══════════════════════════════════════════════════════
                COLOUR PALETTE  — "The Editor's Desk"
            ═══════════════════════════════════════════════════════-->
            <!-- Void Black - main background -->
            <Color x:Key="VoidBlack">#FF141414</Color>
            <!-- Charcoal - panel surfaces -->
            <Color x:Key="Charcoal">#FF1E1E1E</Color>
            <!-- Iron - subtle borders / grid lines -->
            <Color x:Key="Iron">#FF2A2A2A</Color>
            <!-- Ash - secondary text / disabled -->
            <Color x:Key="Ash">#FF6B6B6B</Color>
            <!-- Smoke - primary UI text -->
            <Color x:Key="Smoke">#FFB8B4AC</Color>
            <!-- Paper - drawing surface / primary text on dark -->
            <Color x:Key="Paper">#FFF4F0E8</Color>
            <!-- Irvin Red - THE accent, sparingly applied -->
            <Color x:Key="IrvinRed">#FFE34234</Color>
            <!-- Warm Gold - secondary accent for highlights -->
            <Color x:Key="WarmGold">#FFC9A84C</Color>

            <!-- Brush helpers -->
            <SolidColorBrush x:Key="VoidBlackBrush"  Color="{StaticResource VoidBlack}" />
            <SolidColorBrush x:Key="CharcoalBrush"   Color="{StaticResource Charcoal}" />
            <SolidColorBrush x:Key="IronBrush"       Color="{StaticResource Iron}" />
            <SolidColorBrush x:Key="AshBrush"        Color="{StaticResource Ash}" />
            <SolidColorBrush x:Key="SmokeBrush"      Color="{StaticResource Smoke}" />
            <SolidColorBrush x:Key="PaperBrush"      Color="{StaticResource Paper}" />
            <SolidColorBrush x:Key="IrvinRedBrush"   Color="{StaticResource IrvinRed}" />
            <SolidColorBrush x:Key="WarmGoldBrush"   Color="{StaticResource WarmGold}" />

            <!--═══════════════════════════════════════════════════════
                GLOBAL CONTROL STYLES
            ═══════════════════════════════════════════════════════-->

            <!-- Button style - editorial, borderless -->
            <Style x:Key="EditorialButton" TargetType="Button">
                <Setter Property="Background"           Value="Transparent" />
                <Setter Property="Foreground"           Value="{StaticResource SmokeBrush}" />
                <Setter Property="BorderThickness"      Value="0" />
                <Setter Property="FontFamily"           Value="{StaticResource SerifDisplay}" />
                <Setter Property="FontSize"             Value="13" />
                <Setter Property="Padding"              Value="14,8" />
                <Setter Property="Cursor"               Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{StaticResource IrvinRedBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource PaperBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource IrvinRedBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Accent button (red fill) -->
            <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource EditorialButton}">
                <Setter Property="Background"  Value="{StaticResource IrvinRedBrush}" />
                <Setter Property="Foreground"  Value="{StaticResource PaperBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="1">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#FFD0392A" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#FFBC2E1F" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ToolToggle button for the floating panel -->
            <Style x:Key="ToolToggleButton" TargetType="ToggleButton">
                <Setter Property="Background"      Value="Transparent" />
                <Setter Property="Foreground"      Value="{StaticResource SmokeBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Width"           Value="40" />
                <Setter Property="Height"          Value="40" />
                <Setter Property="Cursor"          Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Width="40" Height="40"
                                    CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#FF2A2A2A"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#33E34234"/></Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource IrvinRedBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Slider (for brush width / opacity) -->
            <Style x:Key="EditorialSlider" TargetType="Slider">
                <Setter Property="Background"          Value="Transparent" />
                <Setter Property="Foreground"          Value="{StaticResource IrvinRedBrush}" />
                <Setter Property="Height"              Value="20" />
                <Setter Property="SmallChange"         Value="0.5" />
                <Setter Property="LargeChange"         Value="2" />
            </Style>

            <!-- Global window/panel background -->
            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource VoidBlackBrush}" />
                <Setter Property="Foreground" Value="{StaticResource SmokeBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource SerifBody}" />
            </Style>

            <!-- TextBlock default -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground"  Value="{StaticResource SmokeBrush}" />
                <Setter Property="FontFamily"  Value="{StaticResource SerifBody}" />
                <Setter Property="FontSize"    Value="13" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
