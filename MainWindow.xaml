<Window x:Class="NoirNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:engine="clr-namespace:NoirNotes.Engine"
        xmlns:controls="clr-namespace:NoirNotes.Controls"
        Title="Noir Notes"
        Width="1440" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource VoidBlackBrush}"
        FontFamily="{StaticResource SerifBody}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing"
        KeyDown="OnWindowKeyDown">

    <Window.Resources>
        <!-- Session page thumbnail style -->
        <Style x:Key="PageThumb" TargetType="Border">
            <Setter Property="Width"            Value="72" />
            <Setter Property="Height"           Value="102" />
            <Setter Property="Background"       Value="#FF1E1E1E" />
            <Setter Property="BorderBrush"      Value="{StaticResource IronBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="2" />
            <Setter Property="Margin"           Value="0,0,0,8" />
            <Setter Property="Cursor"           Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Session strip (collapsed by default) -->
            <ColumnDefinition x:Name="SessionColumn" Width="0" />
            <!-- Main canvas area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <!-- Title bar / toolbar -->
            <RowDefinition Height="44" />
            <!-- Canvas -->
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             SESSION STRIP (Column 0)
             A vertical strip showing saved page thumbnails.
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                Background="#FF1A1A1A"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource IronBrush}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="PAGES"
                           FontSize="9"
                           FontFamily="{StaticResource SerifDisplay}"
                           Foreground="{StaticResource AshBrush}"
                           LetterSpacing="3"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,12" />
                <ScrollViewer DockPanel.Dock="Top"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PageStripPanel"
                                Orientation="Vertical"
                                Margin="8,0" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             TOP TOOLBAR (Row 0, Col 1)
             The editorial masthead bar.
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="0"
                Background="#FF141414"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource IronBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- Left: app identity -->
                    <ColumnDefinition Width="*" />      <!-- Centre: empty / zoom -->
                    <ColumnDefinition Width="Auto" />   <!-- Right: session controls -->
                </Grid.ColumnDefinitions>

                <!-- Left: App identity -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="18,0,0,0">
                    <!-- Red vertical rule — the Irvin accent -->
                    <Rectangle Width="2" Height="22"
                               Fill="{StaticResource IrvinRedBrush}"
                               Margin="0,0,12,0" />
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="NOIR NOTES"
                                   FontFamily="{StaticResource SerifDisplay}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PaperBrush}"
                                   LetterSpacing="4" />
                        <TextBlock x:Name="SubtitleBlock"
                                   Text="infinite canvas edition"
                                   FontSize="9"
                                   FontStyle="Italic"
                                   Foreground="{StaticResource AshBrush}"
                                   LetterSpacing="1" />
                    </StackPanel>
                </StackPanel>

                <!-- Centre: zoom indicator -->
                <TextBlock x:Name="ZoomLabel"
                           Grid.Column="1"
                           Text="100%"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AshBrush}"
                           FontSize="11" />

                <!-- Right: session controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">

                    <!-- Toggle session strip -->
                    <Button Content="≡ Pages"
                            Style="{StaticResource EditorialButton}"
                            Click="OnToggleSessionStrip"
                            ToolTip="Show/hide session strip" />

                    <!-- Save current view as A4 page -->
                    <Button x:Name="BtnSavePage"
                            Content="⊞ Save A4"
                            Style="{StaticResource EditorialButton}"
                            Click="OnSaveAsA4Page"
                            ToolTip="Save current view as an A4 page and clear canvas"
                            Margin="4,0,0,0" />

                    <!-- Export all pages to PDF -->
                    <Button x:Name="BtnExport"
                            Content="↓ Export PDF"
                            Style="{StaticResource AccentButton}"
                            Click="OnExportPdf"
                            ToolTip="Export all saved pages to a PDF file"
                            Margin="8,0,0,0" />

                    <!-- Undo -->
                    <Button Content="↩"
                            Style="{StaticResource EditorialButton}"
                            Click="OnUndo"
                            ToolTip="Undo last stroke  (Ctrl+Z)"
                            FontSize="16"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CANVAS AREA (Row 1, Col 1)
             Contains the InfiniteCanvas and the floating tool panel.
        ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.Row="1" ClipToBounds="True">

            <!-- The infinite drawing surface -->
            <engine:InfiniteCanvas x:Name="Canvas"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Focusable="True"
                                   Cursor="Pen" />

            <!-- Overlay Canvas for the floating panel -->
            <Canvas x:Name="OverlayCanvas"
                    IsHitTestVisible="False">

                <!-- Floating tool panel — re-enable hit-testing on the panel itself -->
                <controls:FloatingToolPanel x:Name="ToolPanel"
                                            Canvas.Left="24"
                                            Canvas.Top="24"
                                            IsHitTestVisible="True"
                                            ToolChanged="OnToolChanged"
                                            Panel.ZIndex="100" />
            </Canvas>

            <!-- "Pen proximity" cursor glow indicator (hidden by default) -->
            <Ellipse x:Name="PenCursor"
                     Width="16" Height="16"
                     Stroke="{StaticResource IrvinRedBrush}"
                     StrokeThickness="1"
                     Opacity="0"
                     IsHitTestVisible="False"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top" />

            <!-- Spacebar pan hint (shows briefly when space is held) -->
            <Border x:Name="PanHint"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20"
                    Background="#AA1E1E1E"
                    CornerRadius="4"
                    Padding="14,6"
                    Visibility="Collapsed">
                <TextBlock Text="PANNING MODE — drag to pan, release Space to draw"
                           Foreground="{StaticResource SmokeBrush}"
                           FontSize="11"
                           FontStyle="Italic" />
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             STATUS BAR (Row 2, Col 1)
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="2"
                Background="#FF0E0E0E"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource IronBrush}"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: tool info -->
                <TextBlock x:Name="StatusLeft"
                           Grid.Column="0"
                           Text="Fountain Pen  ·  Paper"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{StaticResource AshBrush}" />

                <!-- Centre: page count -->
                <TextBlock x:Name="StatusPages"
                           Grid.Column="1"
                           Text="0 pages saved"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{StaticResource AshBrush}"
                           Margin="0,0,20,0" />

                <!-- Right: Wintab indicator -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="WintabDot"
                             Width="6" Height="6"
                             Fill="{StaticResource AshBrush}"
                             Margin="0,0,6,0" />
                    <TextBlock x:Name="WintabLabel"
                               Text="Checking tablet…"
                               FontSize="10"
                               Foreground="{StaticResource AshBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             KEYBOARD SHORTCUT HINTS (overlay, top-right of canvas)
        ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="ShortcutHints"
                Grid.Column="1" Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Background="Transparent"
                IsHitTestVisible="False"
                Opacity="0.4">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Space + drag → pan"  FontSize="9" Foreground="{StaticResource AshBrush}" />
                <TextBlock Text="Scroll wheel → zoom" FontSize="9" Foreground="{StaticResource AshBrush}" Margin="0,2,0,0" />
                <TextBlock Text="Ctrl+Z → undo"       FontSize="9" Foreground="{StaticResource AshBrush}" Margin="0,2,0,0" />
                <TextBlock Text="F → fountain pen"    FontSize="9" Foreground="{StaticResource AshBrush}" Margin="0,2,0,0" />
                <TextBlock Text="C → chisel pen"      FontSize="9" Foreground="{StaticResource AshBrush}" Margin="0,2,0,0" />
                <TextBlock Text="H → highlighter"     FontSize="9" Foreground="{StaticResource AshBrush}" Margin="0,2,0,0" />
                <TextBlock Text="E → eraser"          FontSize="9" Foreground="{StaticResource AshBrush}" Margin="0,2,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
